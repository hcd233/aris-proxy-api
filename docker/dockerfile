FROM golang:1.25.1-alpine3.22 AS builder

ENV CGO_ENABLED=0

RUN apk add --no-cache upx

WORKDIR /app

# 第一步：仅复制依赖声明文件，利用 Docker 层缓存避免重复下载依赖
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

# 第二步：复制源码并构建，利用 Go 编译缓存加速增量编译
COPY cmd ./cmd
COPY internal ./internal
COPY main.go ./

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go build -trimpath -ldflags="-s -w" -o /go/bin/aris-proxy-api \
    && upx --best --lzma /go/bin/aris-proxy-api

# 运行阶段：使用最小基础镜像 + curl 调试工具
FROM alpine:3.22

RUN apk add --no-cache tzdata curl \
    && ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime

ENV TZ=Asia/Shanghai

WORKDIR /app

COPY --from=builder /go/bin/aris-proxy-api /app/aris-proxy-api

EXPOSE 8080

# docker buildx build --platform linux/amd64 -t aris-proxy-api:latest -f docker/dockerfile .
# docker run -d -p 8080:8080 --env-file api.env --name aris-proxy-api -t aris-proxy-api:latest /app/aris-proxy-api server start --host 0.0.0.0 --port 8080
