#!/bin/sh
# Pre-commit hook: run Go checks before committing

# Path to the Go binary — override if Go is installed elsewhere, e.g. /usr/local/go/bin/go
GO_BIN="${GO_BIN:-go}"

# Allow Go to automatically download and switch to the toolchain version
# required by go.mod (e.g. go 1.25.1 when the system only has 1.22.x)
export GOTOOLCHAIN=auto

# Ensure common Go install locations are in PATH
export PATH=$PATH:/usr/local/go/bin:$HOME/go/bin:$HOME/sdk/go/bin

PASS="\033[32m[PASS]\033[0m"
FAIL="\033[31m[FAIL]\033[0m"
INFO="\033[34m[INFO]\033[0m"

fail() {
    printf "$FAIL %s\n" "$1"
    exit 1
}

# --------------------------------------------------------------------------
# 1. codegraph sync — sync file changes to the code knowledge graph index
# --------------------------------------------------------------------------
printf "$INFO Running codegraph sync ...\n"

if command -v codegraph >/dev/null 2>&1; then
    SYNC_OUTPUT=$(codegraph sync 2>&1)
    SYNC_EXIT=$?
    if [ $SYNC_EXIT -ne 0 ]; then
        # "database is locked" is transient (MCP server holds a reader lock)
        if echo "$SYNC_OUTPUT" | grep -q "database is locked"; then
            printf "$INFO codegraph database locked by MCP server — skipping (index stays fresh after next MCP query)\n"
        else
            printf "$FAIL codegraph sync failed:\n"
            echo "$SYNC_OUTPUT" | sed 's/^/       /'
            fail "codegraph sync failed. Ensure .codegraph/ exists and is healthy."
        fi
    fi
else
    printf "$INFO codegraph CLI not found — skipping\n"
fi
printf "$PASS codegraph sync\n"

# --------------------------------------------------------------------------
# 2. gofmt — auto-format source files and re-stage changed files
# --------------------------------------------------------------------------
printf "$INFO Running gofmt -w ...\n"
gofmt -w .

if ! git diff --quiet; then
    FORMATTED=$(git diff --name-only)
    printf "$INFO gofmt reformatted the following files (auto-staging):\n"
    echo "$FORMATTED" | sed 's/^/       /'
    echo ""
    git add $FORMATTED
fi
printf "$PASS gofmt\n"

# --------------------------------------------------------------------------
# 3. go mod tidy — verify go.mod / go.sum are consistent and re-stage
# --------------------------------------------------------------------------
printf "$INFO Running go mod tidy...\n"
$GO_BIN mod tidy

if ! git diff --quiet go.mod go.sum; then
    printf "$INFO go.mod or go.sum changed after 'go mod tidy' (auto-staging):\n"
    git diff --name-only go.mod go.sum | sed 's/^/       /'
    echo ""
    git add go.mod go.sum
fi
printf "$PASS go mod tidy\n"

# --------------------------------------------------------------------------
# 4. go vet — static analysis
# --------------------------------------------------------------------------
printf "$INFO Running go vet ./...\n"

if ! $GO_BIN vet ./... 2>&1; then
    fail "go vet failed. Please fix the issues above before committing."
fi
printf "$PASS go vet\n"

# --------------------------------------------------------------------------
# 5. go test — run all unit tests, block commit on any failure
# --------------------------------------------------------------------------
printf "$INFO Running go test -count=1 ./...\n"

if ! $GO_BIN test -count=1 ./... 2>&1; then
    fail "go test failed. All tests must pass before committing."
fi
printf "$PASS go test\n"

# --------------------------------------------------------------------------
# 6. lint — project convention lint
# --------------------------------------------------------------------------
printf "$INFO Running lint...\n"

if ! $GO_BIN run main.go lint ./... 2>&1; then
    fail "lint failed. Please fix the convention violations above before committing."
fi
printf "$PASS lint\n"

# --------------------------------------------------------------------------
echo ""
printf "$PASS All checks passed. Proceeding with commit.\n"
