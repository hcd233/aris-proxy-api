    {
        "name": "response_text_format_json_schema",
        "description": "text format json_schema converts to Anthropic output config",
        "openai_response_request": {
            "model": "gpt-4o",
            "input": [
                {
                    "type": "message",
                    "role": "user",
                    "content": [
                        {"type": "input_text", "text": "Return JSON"}
                    ]
                }
            ],
            "text": {
                "format": {
                    "type": "json_schema",
                    "schema": {
                        "type": "object",
                        "properties": {
                            "answer": {"type": "string"}
                        }
                    }
                }
            },
            "max_output_tokens": 1024
        },
        "anthropic_request": {
            "model": "claude-3-5-sonnet",
            "max_tokens": 1024,
            "messages": [
                {"role": "user", "content": "Return JSON"}
            ],
            "output_config": {
                "type": "json_schema",
                "schema": {
                    "properties": {"answer": {"type": "string"}},
                    "type": "object"
                }
            }
        }
    },
