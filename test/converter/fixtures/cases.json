    {
        "name": "image_content",
        "description": "image content in user messages converts between protocols",
        "openai_request": {
            "model": "gpt-4-vision",
            "messages": [
                {
                    "role": "user",
                    "content": [
                        {"type": "text", "text": "What is in this image?"},
                        {"type": "image_url", "image_url": {"url": "data:image/png;base64,iVBORw0KGgo="}}
                    ]
                }
            ],
            "max_completion_tokens": 1024
        },
        "anthropic_request": {
            "model": "claude-3-5-sonnet",
            "max_tokens": 1024,
            "messages": [
                {
                    "role": "user",
                    "content": [
                        {"type": "text", "text": "What is in this image?"},
                        {"type": "image", "source": {"type": "base64", "media_type": "image/png", "data": "iVBORw0KGgo="}}
                    ]
                }
            ]
        }
    },
    {
        "name": "tool_no_parameters",
        "description": "tools with no parameters should omit parameters field for OpenAI",
        "anthropic_request": {
            "model": "claude-3-5-sonnet",
            "max_tokens": 100,
            "messages": [{"role": "user", "content": "List all cron jobs"}],
            "tools": [
                {
                    "name": "CronList",
                    "description": "List all cron jobs scheduled via CronCreate",
                    "input_schema": {
                        "type": "object",
                        "additionalProperties": false,
                        "$schema": "https://json-schema.org/draft/2020-12/schema"
                    }
                }
            ]
        }
    }
]
