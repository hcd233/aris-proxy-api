[
    {
        "name": "alias_hit",
        "description": "model 表中找到 alias，endpoint 存在，正常返回",
        "modelBehavior": "hit",
        "endpointBehavior": "hit",
        "alias": "test-model",
        "expectResolved": true,
        "expectErrKind": ""
    },
    {
        "name": "alias_miss",
        "description": "model 表找不到 alias，返回 ErrDataNotExists",
        "modelBehavior": "miss",
        "endpointBehavior": "unused",
        "alias": "nonexistent",
        "expectResolved": false,
        "expectErrKind": "not_exists"
    },
    {
        "name": "model_db_error",
        "description": "model 表 DB 错误直接上抛",
        "modelBehavior": "db_error",
        "endpointBehavior": "unused",
        "alias": "gpt-4",
        "expectResolved": false,
        "expectErrKind": "db_query"
    },
    {
        "name": "empty_alias",
        "description": "空别名返回 ErrValidation",
        "modelBehavior": "unused",
        "endpointBehavior": "unused",
        "alias": "",
        "expectResolved": false,
        "expectErrKind": "validation"
    }
]
