        "tools": [],
        "expected_tool_ids": [],
        "expected_tool_names": [],
        "expected_tool_count": 0
    },
    {
        "name": "build_ordered_tools_populates_fields",
        "description": "all fields should be correctly populated",
        "tool_ids": [7],
        "tools": [
            {"id": 7, "tool": {"provider": "openai", "name": "CodeRunner", "description": "Run code", "parameters": null}, "created_at": "2026-03-19T10:30:00Z"}
