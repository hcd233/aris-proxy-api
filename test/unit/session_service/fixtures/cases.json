[
    {
        "name": "build_ordered_messages_preserves_order",
        "description": "messages should be returned in the order specified by ids",
        "message_ids": [1, 2, 3],
        "messages": [
            {"id": 3, "model": "gpt-4", "message": {"role": "user"}, "created_at": "2026-03-19T10:00:00Z"},
            {"id": 1, "model": "gpt-4", "message": {"role": "assistant"}, "created_at": "2026-03-19T10:00:00Z"},
            {"id": 2, "model": "claude-3", "message": {"role": "user"}, "created_at": "2026-03-19T10:00:00Z"}
        ],
        "expected_ids": [1, 2, 3],
        "expected_count": 3
    },
    {
        "name": "build_ordered_messages_skips_missing_ids",
        "description": "messages with missing IDs should be skipped",
        "message_ids": [1, 2, 3],
        "messages": [
            {"id": 1, "model": "gpt-4", "message": {"role": "user"}, "created_at": "2026-03-19T10:00:00Z"},
            {"id": 3, "model": "gpt-4", "message": {"role": "assistant"}, "created_at": "2026-03-19T10:00:00Z"}
        ],
        "expected_ids": [1, 3],
        "expected_count": 2
    },
    {
        "name": "build_ordered_messages_empty_ids",
        "description": "empty ids should return empty result",
        "message_ids": [],
        "messages": [],
        "expected_ids": [],
        "expected_count": 0
    },
    {
        "name": "build_ordered_messages_populates_fields",
        "description": "all fields should be correctly populated",
        "message_ids": [5],
        "messages": [
            {"id": 5, "model": "gpt-4.1", "message": {"role": "user", "content": "hello"}, "created_at": "2026-03-19T10:00:00Z"}
        ],
        "expected_ids": [5],
        "expected_count": 1,
        "expected_model": "gpt-4.1",
        "expected_role": "user",
        "expected_created_at": "2026-03-19 10:00:00"
    },
    {
        "name": "build_ordered_tools_preserves_order",
        "description": "tools should be returned in the order specified by ids",
        "tool_ids": [1, 2],
        "tools": [
            {"id": 2, "tool": {"provider": "openai", "name": "Bash", "description": "Execute bash", "parameters": null}, "created_at": "2026-03-19T10:00:00Z"},
            {"id": 1, "tool": {"provider": "openai", "name": "Search", "description": "Search code", "parameters": null}, "created_at": "2026-03-19T10:00:00Z"}
        ],
        "expected_tool_ids": [1, 2],
        "expected_tool_names": ["Search", "Bash"],
        "expected_tool_count": 2
    },
    {
        "name": "build_ordered_tools_skips_missing_ids",
        "description": "tools with missing IDs should be skipped",
        "tool_ids": [1, 99],
        "tools": [
            {"id": 1, "tool": {"provider": "openai", "name": "Bash", "description": "Execute bash", "parameters": null}, "created_at": "2026-03-19T10:00:00Z"}
        ],
        "expected_tool_ids": [1],
        "expected_tool_names": ["Bash"],
        "expected_tool_count": 1
