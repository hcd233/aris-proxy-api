[
    {
        "name": "same_tool_same_params",
        "description": "相同工具和参数应产生相同checksum",
        "tools": [
            {
                "provider": "openai",
                "name": "Bash",
                "description": "Execute a bash command",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": {
                            "type": "string",
                            "description": "The bash command to execute"
                        },
                        "timeout": {
                            "type": "integer",
                            "description": "Timeout in seconds"
                        }
                    },
                    "required": ["command"]
                }
            },
            {
                "provider": "openai",
                "name": "Bash",
                "description": "Execute a bash command",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": {
                            "type": "string",
                            "description": "The bash command to execute"
                        },
                        "timeout": {
                            "type": "integer",
                            "description": "Timeout in seconds"
                        }
                    },
                    "required": ["command"]
                }
            }
        ],
        "expect_equal": true
    },
